<!-- BẢNG 2: HỒI QUY ĐA BIẾN -->
<h2>BẢNG 2: Phân tích Hồi quy Đa biến — Yếu tố Ảnh hưởng đến Hành vi Tích cực (N=1200)</h2>
<table>
    <tr class="section-header"><td colspan="7">2. Regression Analysis — Predictors of Positive Behavior</td></tr>
    <tr>
        <th>Biến độc lập (Predictor)</th>
        <th>β (Standardized)</th>
        <th>SE</th>
        <th>t-value</th>
        <th>p-value</th>
        <th>95% CI Lower</th>
        <th>95% CI Upper</th>
    </tr>
    <tr>
        <td class="label">Năng lực giáo viên (Teacher Competence)</td>
        <td class="highlight">0.42</td>
        <td>0.038</td>
        <td>11.05</td>
        <td>&lt;0.001</td>
        <td>0.345</td>
        <td>0.495</td>
    </tr>
    <tr>
        <td class="label">Chất lượng MT lớp học (Classroom Environment)</td>
        <td class="highlight">0.31</td>
        <td>0.041</td>
        <td>7.56</td>
        <td>&lt;0.001</td>
        <td>0.230</td>
        <td>0.390</td>
    </tr>
    <tr>
        <td class="label">Phong cách nuôi dạy GĐ (Parenting Style)</td>
        <td>0.24</td>
        <td>0.035</td>
        <td>6.86</td>
        <td>&lt;0.001</td>
        <td>0.171</td>
        <td>0.309</td>
    </tr>
    <tr>
        <td class="label">Sĩ số lớp — nghịch biến (Class Size)</td>
        <td class="warning">-0.19</td>
        <td>0.032</td>
        <td>-5.94</td>
        <td>&lt;0.001</td>
        <td>-0.253</td>
        <td>-0.127</td>
    </tr>
    <tr>
        <td class="label">Tương tác bạn đồng trang lứa (Peer Interaction)</td>
        <td>0.16</td>
        <td>0.040</td>
        <td>4.00</td>
        <td>&lt;0.001</td>
        <td>0.082</td>
        <td>0.238</td>
    </tr>
    <tr class="sub-header">
        <td colspan="7">Model Summary: R² = 0.67, Adjusted R² = 0.66, F(5, 1194) = 482.3, p &lt; 0.001</td>
    </tr>
</table>

<!-- BẢNG 3: KẾT QUẢ CAN THIỆP PBIS-VN -->
<h2>BẢNG 3: Kết quả Can thiệp PBIS-VN — Pre-Post Comparison (N=320, 6 tháng)</h2>
<table>
    <tr class="section-header"><td colspan="7">3. PBIS-VN Intervention Results — Paired t-test</td></tr>
    <tr>
        <th>Chỉ số hành vi (Behavior Indicator)</th>
        <th>Pre-test M±SD</th>
        <th>Post-test M±SD</th>
        <th>Change (%)</th>
        <th>Cohen's d</th>
        <th>t-value</th>
        <th>p-value</th>
    </tr>
    <tr>
        <td class="label">Hợp tác với bạn (Cooperation)</td>
        <td>2.8 ± 0.9</td>
        <td>3.9 ± 0.7</td>
        <td class="highlight">+39.3%</td>
        <td>1.36</td>
        <td>12.45</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Chia sẻ (Sharing)</td>
        <td>2.5 ± 1.0</td>
        <td>3.6 ± 0.8</td>
        <td class="highlight">+44.0%</td>
        <td>1.21</td>
        <td>11.28</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Kiểm soát cảm xúc (Emotion Regulation)</td>
        <td>2.3 ± 1.1</td>
        <td>3.2 ± 0.9</td>
        <td class="highlight">+39.1%</td>
        <td>0.90</td>
        <td>8.67</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Giải quyết xung đột (Conflict Resolution)</td>
        <td>2.1 ± 0.8</td>
        <td>2.9 ± 0.7</td>
        <td class="highlight">+38.1%</td>
        <td>1.07</td>
        <td>9.85</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Thể hiện đồng cảm (Empathy)</td>
        <td>2.6 ± 0.9</td>
        <td>3.4 ± 0.8</td>
        <td class="highlight">+30.8%</td>
        <td>0.94</td>
        <td>9.12</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Tuân thủ quy tắc (Rule Following)</td>
        <td>3.1 ± 0.8</td>
        <td>4.0 ± 0.6</td>
        <td class="highlight">+29.0%</td>
        <td>1.27</td>
        <td>11.82</td>
        <td>&lt;0.001</td>
    </tr>
    <tr>
        <td class="label">Hành vi không mong muốn (Problem Behaviors)</td>
        <td>3.4 ± 1.2</td>
        <td>2.1 ± 0.9</td>
        <td class="warning">-38.2%</td>
        <td>1.23</td>
        <td>-11.45</td>
        <td>&lt;0.001</td>
    </tr>
    <tr class="highlight">
        <td class="label"><b>TỔNG HỢP (OVERALL MEAN)</b></td>
        <td><b>2.69 ± 0.96</b></td>
        <td><b>3.30 ± 0.77</b></td>
        <td><b>+34.7%</b></td>
        <td><b>1.14</b></td>
        <td><b>—</b></td>
        <td><b>&lt;0.001</b></td>
    </tr>
</table>

